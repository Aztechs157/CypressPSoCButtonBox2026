        }
        pin (out_clock_en) {
            direction : input;
        }
        pin (out_reset) {
            direction : input;
        }
        pin (pin_input) {
            direction : input;
        }
        pin (pa_out) {
            direction : output;
        }
        pin (oe) {
            direction : input;
        }
        pin (pad_in) {
            direction : input;
        }
        pin (pad_out) {
            direction : output;
            timing () {
                timing_sense : negative_unate;
                timing_type : three_state_disable;
                related_pin : "oe";
                intrinsic_rise : 17.787;
                intrinsic_fall : 17.787;
            }
            timing () {
                timing_sense : positive_unate;
                timing_type : three_state_enable;
                related_pin : "oe";
                intrinsic_rise : 17.787;
                intrinsic_fall : 17.787;
            }
            timing () {
                timing_sense : positive_unate;
                timing_type : combinational;
                related_pin : "pin_input";
                intrinsic_rise : 15.338;
                intrinsic_fall : 15.338;
            }
        }
        pin (fb) {
            direction : output;
            timing () {
                timing_sense : positive_unate;
                timing_type : combinational;
                related_pin : "pad_in";
                intrinsic_rise : 6.774;
                intrinsic_fall : 6.774;
            }
        }
    }
